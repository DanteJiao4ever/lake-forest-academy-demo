NODE_ENV=development
HOST=127.0.0.1
PORT=8787
DATABASE_URL=postgresql://lfa_api:replace-me@127.0.0.1:5432/lfa_learning
DATABASE_SSL=false

# Exact browser origins permitted to send credentialed requests.
ALLOWED_ORIGINS=https://lakeforestacademy.ca,https://www.lakeforestacademy.ca,http://localhost:5173,http://127.0.0.1:5173
# Development value. Production must use __Host-lfa_session.
COOKIE_NAME=lfa_session
COOKIE_SECURE=false
SESSION_TTL_HOURS=12
BCRYPT_COST=12
CSRF_SECRET=replace-with-at-least-32-random-bytes-from-secret-manager

# Google service-account JSON must be supplied by the host secret manager.
# Use either GOOGLE_APPLICATION_CREDENTIALS or base64-encoded JSON below.
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_APPLICATION_CREDENTIALS=

# Folder IDs are identifiers, not credentials. This is the approved staff-only
# Student Submissions root currently supplied by the school.
SUBMISSION_TARGET_ROOT_ID=1vDhdvq7y15q6AEklYR0wq0PZAH2wkcVK

# ClamAV INSTREAM scanning. Required in production unless a different scanner
# is injected by the deployment adapter.
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_REQUIRED=false

MAX_UPLOAD_FILES=1
MAX_FILE_BYTES=26214400
MAX_REQUEST_BYTES=29360128

# Optional first-party Workspace OAuth may be added without changing the
# cookie session contract. Faculty users are provisioned with create-user.
